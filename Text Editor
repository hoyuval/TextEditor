        const targets = {
            ' ': { class: 'vis-char space' }, '\xA0': { class: 'vis-char nbsp' }, '\t': { class: 'vis-char tab' },
            '\u200F': { class: 'vis-ctrl rlm', label: 'RLM' }, '\u200E': { class: 'vis-ctrl lrm', label: 'LRM' },
            '\u202B': { class: 'vis-ctrl rle', label: 'RLE' }, '\u202A': { class: 'vis-ctrl lre', label: 'LRE' }
        };
        const targetRegex = /([ \xA0\t\u200F\u200E\u202B\u202A])/g; const testRegex = /[ \xA0\t\u200F\u200E\u202B\u202A]/;

        function showModal(msg, cb) {
            document.getElementById('modalMessage').textContent = msg;
            const btn = document.getElementById('modalConfirm'); const nBtn = btn.cloneNode(true); btn.parentNode.replaceChild(nBtn, btn);
