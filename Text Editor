                if (isDiffActive) toggleDiffMode(true);
            }

            if (state.mode === 'single' || state.mode === 'comparison') {
                setRawText(textInput, state.text1);
                if (state.mode === 'comparison') setRawText(textInput2, state.text2);
                if (isComparisonMode && isDiffActive) updateDiff();
            } else if (state.mode === 'segmentation') {
                segments = state.segments.map(s => ({id: crypto.randomUUID(), text: s.text, trailingSpace: s.trailingSpace}));
                renderSegments();
