        const dmp = new diff_match_patch(); dmp.Diff_Timeout = 0;

        let isVisualizationActive = true, isComparisonMode = false, isDiffActive = false;
        let isSegmentationMode = false, isTagsMode = false, hasScannedTags = false;
        let segmentationRule = 'paragraph';
        let segments = [], tagRegistry = [];
        let activeSegmentIndex = -1, currentDirectionMode = 'auto'; 
        let activeInput = textInput, updateTimeout, forceFormat = false; 

        // --- Custom Undo Stack ---
        let historyStack = [];
        let historyIndex = -1;
        let isNavigatingHistory = false;
        let historyTimeout;

        function saveHistoryState() {
            if (isNavigatingHistory) return;
            const state = {
                mode: isSegmentationMode ? 'segmentation' : (isComparisonMode ? 'comparison' : 'single'),
                text1: getRawText(textInput),
                text2: isComparisonMode ? getRawText(textInput2) : '',
                segments: isSegmentationMode ? segments.map(s => ({text: s.text, trailingSpace: s.trailingSpace})) : []
            };
            
            if (historyIndex >= 0) {
                const last = historyStack[historyIndex];
                if (last.mode === state.mode && last.text1 === state.text1 && last.text2 === state.text2 && JSON.stringify(last.segments) === JSON.stringify(state.segments)) return;
            }

            if (historyIndex < historyStack.length - 1) {
                historyStack = historyStack.slice(0, historyIndex + 1);
            }
            
            historyStack.push(state);
            if (historyStack.length > 50) historyStack.shift();
            else historyIndex++;
        }

        function customUndo() {
            if (historyIndex > 0) {
                isNavigatingHistory = true;
                historyIndex--;
                applyHistoryState(historyStack[historyIndex]);
                isNavigatingHistory = false;
            }
        }

        function customRedo() {
            if (historyIndex < historyStack.length - 1) {
                isNavigatingHistory = true;
                historyIndex++;
                applyHistoryState(historyStack[historyIndex]);
                isNavigatingHistory = false;
            }
        }

        function applyHistoryState(state) {
            forceFormat = true;
            
            if (state.mode === 'segmentation' && !isSegmentationMode) {
                isSegmentationMode = true;
                document.getElementById('segmentationBtn').classList.add('is-active-btn'); 
                document.getElementById('segmentationToolbar').classList.remove('hidden');
                document.getElementById('editorGrid').classList.add('hidden'); 
                segmentationGrid.classList.remove('hidden');
            } else if (state.mode !== 'segmentation' && isSegmentationMode) {
                isSegmentationMode = false;
                document.getElementById('segmentationBtn').classList.remove('is-active-btn'); 
                document.getElementById('segmentationToolbar').classList.add('hidden');
                document.getElementById('editorGrid').classList.remove('hidden'); 
                segmentationGrid.classList.add('hidden');
            }

            if (state.mode === 'comparison' && !isComparisonMode) {
                isComparisonMode = true;
                document.getElementById('comparisonBtn').classList.add('is-active-btn'); 
                rightCol.classList.remove('hidden'); 
                document.getElementById('diffToggleButton').classList.remove('hidden'); 
