<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTL Text Editor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/diff_match_patch/20121119/diff_match_patch.js"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --font-sans: 'Google Sans', 'Product Sans', 'Noto Sans', system-ui, sans-serif; --btn-blue: #6d9eeb; --text-size: 1rem; }
        html, body { height: 100%; margin: 0; padding: 0; overflow: hidden; font-family: var(--font-sans); background-color: #ffffff; color: #1f2937; transition: background-color 0.3s, color 0.3s; }
        .material-symbols-outlined { font-size: 1.25rem; line-height: 1; }
        .app-container { display: flex; flex-direction: column; height: 100%; width: 100%; padding: 1rem; box-sizing: border-box; }
        .app-header { flex-shrink: 0; margin-bottom: 1rem; }
        .app-editor-area { flex-grow: 1; min-height: 200px; overflow: hidden; display: flex; flex-direction: column; margin-bottom: 1rem; }
        .app-footer { flex-shrink: 0; height: 30vh; overflow-y: auto; border-top: 1px solid #e5e7eb; padding-top: 1rem; padding-bottom: 2rem; transition: border-color 0.3s; }
        .editor-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; height: 100%; width: 100%; }
        .editor-grid.comparison-active { grid-template-columns: 1fr 1fr; }
        .editor-col { display: flex; flex-direction: column; height: 100%; overflow: hidden; min-height: 0; }
        .editor-label { font-size: 0.875rem; font-weight: 700; color: #4b5563; margin-bottom: 0.25rem; }
        .editor-wrapper { flex-grow: 1; display: flex; flex-direction: column; border: 1px solid #d1d5db; border-radius: 0.5rem; background-color: #fff; position: relative; transition: background-color 0.3s, border-color 0.3s; overflow: hidden; min-height: 0; }
        
        .text-input { flex-grow: 1; width: 100%; padding: 1rem; font-family: var(--font-sans); font-size: var(--text-size); line-height: 1.6; letter-spacing: normal; word-spacing: 0.15em; overflow-y: auto; white-space: pre-wrap; outline: none; box-sizing: border-box; caret-color: #1f2937; tab-size: 4; position: relative; min-height: 0; }
        .text-input.is-empty::before { content: attr(data-placeholder); color: #9ca3af; position: absolute; pointer-events: none; font-family: var(--font-sans); }
        .text-input[dir="rtl"] { text-align: right; }
        .editor-block { position: relative; min-height: 1.5em; }

        .vis-pilcrow { position: relative; color: var(--btn-blue) !important; opacity: 1 !important; margin-inline-start: 0.05em; pointer-events: none; user-select: none; font-weight: 700 !important; font-family: var(--font-sans) !important; z-index: 1; }
        .text-input.show-vis .vis-char, .text-input.show-vis .vis-ctrl { color: transparent !important; caret-color: #1f2937 !important; position: relative; white-space: pre-wrap !important; z-index: 1; }
        .text-input.show-vis .vis-char.space::before { content: '·'; color: var(--btn-blue); position: absolute; left: 0; right: 0; text-align: center; pointer-events: none; user-select: none; font-weight: 700; z-index: 10; }
        .text-input.show-vis .vis-char.nbsp::before { content: '∘'; color: var(--btn-blue); position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); font-size: 1.4em; pointer-events: none; user-select: none; font-weight: 700; z-index: 10; }
        .text-input.show-vis .vis-char.tab::before { content: '→'; color: var(--btn-blue); position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); pointer-events: none; user-select: none; font-weight: 700; z-index: 10; }
        
        .text-input.show-vis .vis-ctrl { padding-inline-start: 1.2em; unicode-bidi: normal; }
        .text-input.show-vis .vis-ctrl::before { content: attr(data-label); position: absolute; left: 50%; top: 50%; color: var(--btn-blue); font-size: 0.55em; font-family: var(--font-sans); pointer-events: none; user-select: none; letter-spacing: normal; transform: translate(-50%, -50%) rotate(-45deg); z-index: 10; font-weight: 700; text-decoration: none; }


        /* ================================================================================= */
        /* THE FIXED SELECTION RIBBON ENGINE                                                 */
        /* ================================================================================= */

        /* 1. Global Native Selection (Text & Spaces) */
        .text-input:focus *::selection { background-color: #add6ff !important; color: #000 !important; }
        .text-input:not(:focus) *::selection { background-color: #e5e7eb !important; color: inherit !important; }
        
        /* 2. Hide Native Text inside Spaces when selected */
        .text-input.show-vis .vis-char::selection { background-color: #add6ff !important; color: transparent !important; }
        .text-input:not(:focus).show-vis .vis-char::selection { background-color: #e5e7eb !important; color: transparent !important; }
        
        /* 3. Disable Native Selection on Custom Objects (Prevents Dark Border Overlaps) */
        .app-tag::selection, .app-tag-ph::selection, .app-tag-custom::selection, .vis-ctrl::selection, .vis-pilcrow::selection,
        .app-tag *::selection, .app-tag-ph *::selection, .app-tag-custom *::selection, .vis-ctrl *::selection, .vis-pilcrow *::selection { background-color: transparent !important; color: inherit !important; }

        /* 4. The Master Overlay Ribbon (1.35rem fixed height, mathematically independent) */
        .app-tag.is-selected::after, .app-tag-ph.is-selected::after, .app-tag-custom.is-selected::after, .vis-ctrl.is-selected::after, .vis-pilcrow.is-selected::after {
            content: ''; position: absolute; left: -1px; right: -1px; 
            top: 50%; height: 1.35rem; transform: translateY(-50%);
            z-index: -2; pointer-events: none; border-radius: 0 !important;
        }

        /* Focus & Unfocus Ribbon Colors */
        .text-input:focus .app-tag.is-selected::after, .text-input:focus .app-tag-ph.is-selected::after, .text-input:focus .app-tag-custom.is-selected::after, .text-input:focus .vis-ctrl.is-selected::after, .text-input:focus .vis-pilcrow.is-selected::after {
            background-color: #add6ff !important;
        }
        .text-input:not(:focus) .app-tag.is-selected::after, .text-input:not(:focus) .app-tag-ph.is-selected::after, .text-input:not(:focus) .app-tag-custom.is-selected::after, .text-input:not(:focus) .vis-ctrl.is-selected::after, .text-input:not(:focus) .vis-pilcrow.is-selected::after {
            background-color: #e5e7eb !important;
        }

        /* 5. High-Contrast Icon Inversion (Black on Focus, Dark Gray on Blur) */
        .text-input:focus .is-selected.vis-char::before, .text-input:focus .is-selected.vis-ctrl::before, .text-input:focus .is-selected.vis-pilcrow { color: #000000 !important; }
        .text-input:not(:focus) .is-selected.vis-char::before, .text-input:not(:focus) .is-selected.vis-ctrl::before, .text-input:not(:focus) .is-selected.vis-pilcrow { color: #4b5563 !important; }


        /* ================================================================================= */

        .text-input.show-vis .bg-red-200.vis-ctrl { background-image: linear-gradient(transparent 45%, #b91c1c 45%, #b91c1c 55%, transparent 55%) !important; text-decoration: none !important; }
        .text-input.show-vis .bg-red-200.vis-ctrl::before { color: #b91c1c !important; text-decoration: none !important; }

        /* Tags Base Wrapper */
        .app-tag { display: inline-block; cursor: default; white-space: pre !important; vertical-align: baseline; margin: 0 1px; color: #4b5563; font-family: monospace; font-size: 0.75rem; font-weight: 600; padding: 2px 4px; -webkit-user-select: none; user-select: none; position: relative; z-index: 1; background-color: transparent !important; }
        .app-tag-custom { display: inline; cursor: default; -webkit-user-select: none; user-select: none; position: relative; z-index: 1; background-color: transparent !important; }
        .app-tag-ph { display: inline-block; cursor: default; white-space: pre !important; color: #166534; font-family: inherit; font-size: inherit; font-weight: inherit; padding: 2px 6px; margin: 0 1px; -webkit-user-select: none; user-select: none; position: relative; z-index: 1; background-color: transparent !important; }
        
        /* The Grey Shapes (Rendered via ::before so ribbon ::after can underlay them safely) */
        .app-tag::before { content: ''; position: absolute; inset: 0; background-color: #e5e7eb; border-radius: 4px; z-index: -1; }
        .app-tag-ph::before { content: ''; position: absolute; inset: 0; background-color: #dcfce7; border-radius: 4px; z-index: -1; }
        .app-tag.tag-standalone::before { border-radius: 6px; }

        /* Ghost Tags when Highlighted (Shows the Ribbon underneath) */
        .text-input:focus .app-tag.is-selected::before { background-color: rgba(255, 255, 255, 0.4) !important; }
        .text-input:not(:focus) .app-tag.is-selected::before { background-color: rgba(255, 255, 255, 0.6) !important; }
        .text-input:focus .app-tag-ph.is-selected::before { background-color: rgba(255, 255, 255, 0.4) !important; }
        .text-input:not(:focus) .app-tag-ph.is-selected::before { background-color: rgba(255, 255, 255, 0.6) !important; }

        /* Formatting */
        .format-wrapper-active { display: inline; }
        .app-tag-hidden { display: none !important; }
        
        .text-theme-blue { color: var(--btn-blue) !important; }
        .hover-theme-blue:hover { color: var(--btn-blue) !important; filter: brightness(0.8); }
        .selectable-input { -webkit-user-select: text !important; user-select: text !important; cursor: text !important; pointer-events: auto !important; }

        /* Arrow Shapes for Tag Pairs */
        .app-tag.tag-opener { padding-right: 12px; padding-left: 6px; }
        .app-tag.tag-opener::before { clip-path: polygon(0% 0%, calc(100% - 8px) 0%, 100% 50%, calc(100% - 8px) 100%, 0% 100%); border-radius: 4px 0 0 4px; }
        .app-tag.tag-closer { padding-left: 12px; padding-right: 6px; }
        .app-tag.tag-closer::before { clip-path: polygon(8px 0%, 100% 0%, 100% 100%, 8px 100%, 0% 50%); border-radius: 0 4px 4px 0; }
        
        .text-input:dir(rtl) .app-tag.tag-opener::before { clip-path: polygon(8px 0%, 100% 0%, 100% 100%, 8px 100%, 0% 50%); border-radius: 0 4px 4px 0; }
        .text-input:dir(rtl) .app-tag.tag-closer::before { clip-path: polygon(0% 0%, calc(100% - 8px) 0%, 100% 50%, calc(100% - 8px) 100%, 0% 100%); border-radius: 4px 0 0 4px; }

        /* Diff Mode Integration */
        .diff-del-text { background-color: #fecaca; color: #991b1b; text-decoration: line-through; text-decoration-color: #ef4444; }
        .diff-del-text .app-tag::before, .diff-del-text .app-tag-ph::before { background-color: #fca5a5 !important; border: 1px solid #ef4444 !important; }
        .diff-del-text .app-tag { color: #991b1b !important; text-decoration: line-through !important; text-decoration-color: #ef4444 !important; }
        .diff-del-text .vis-char::before { color: #991b1b !important; text-decoration: line-through !important; text-decoration-color: #ef4444 !important; }
        .diff-del-text .vis-ctrl { background-image: linear-gradient(transparent 45%, #ef4444 45%, #ef4444 55%, transparent 55%) !important; text-decoration: none !important; }
        .diff-del-text .vis-ctrl::before { color: #991b1b !important; text-decoration: none !important; }
        
        .diff-add-text { background-color: #bbf7d0; border-bottom: 2px solid #16a34a; color: #14532d; }
        .diff-add-text .app-tag::before, .diff-add-text .app-tag-ph::before { background-color: #86efac !important; border: 1px solid #22c55e !important; }
        .diff-add-text .app-tag { color: #14532d !important; }

        /* UI Toolbar */
        .control-row { display: flex; justify-content: flex-start; gap: 0.5rem; flex-wrap: wrap; align-items: center; user-select: none; }
        .control-btn { padding: 0; cursor: pointer; border-radius: 0.5rem; transition: all 0.2s; height: 2.5rem; width: 2.5rem; display: flex; align-items: center; justify-content: center; background-color: #ffffff; color: #4b5563; border: 1px solid #d1d5db; flex-shrink: 0; }
        .control-btn:hover { background-color: #e5e7eb; }
        .control-btn.is-active-btn { background-color: var(--btn-blue); color: white; border-color: var(--btn-blue); }
        .toggle-container { display: flex; border: 1px solid #d1d5db; border-radius: 0.5rem; overflow: hidden; padding: 0.125rem; height: 2.5rem; background-color: #ffffff; align-items: center; transition: background-color 0.3s, border-color 0.3s; flex-shrink: 0; }
        .toggle-container > .control-btn { border: none; height: 100%; border-radius: 0.375rem; padding: 0 0.5rem; width: auto; min-width: 2.25rem; }
        
        .dropdown-wrapper { position: relative; height: 2.5rem; display: flex; align-items: center; }
        .dropdown-menu { position: absolute; z-index: 50; background-color: white; border: 1px solid #d1d5db; border-radius: 0.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); margin-top: 0.25rem; top: 100%; left: 0; width: max-content; transition: background-color 0.3s, border-color 0.3s; }
        .dropdown-menu button { display: block; width: 100%; text-align: left; padding: 0.5rem 1rem; background: transparent; cursor: pointer; border:none; color: inherit; }
        .dropdown-menu button:hover { background-color: #f3f4f6; }

        .stats-container { font-size: 0.85rem; color: #4b5563; margin-bottom: 1rem; }
        .stat-group { display: flex; gap: 1.5rem; flex-wrap: wrap; padding: 0.75rem; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 0.5rem; margin-bottom: 0.5rem; transition: background-color 0.3s, border-color 0.3s; }
        .stat-item { display: flex; gap: 0.5rem; }
        .stat-value { font-weight: 700; color: #111827; }
        
        .tools-section { background-color: #f9fafb; border: 1px solid #d1d5db; border-radius: 0.75rem; padding: 1rem; margin-bottom: 1rem; transition: background-color 0.3s, border-color 0.3s; }
        .section-title { font-size: 0.9rem; font-weight: 700; color: #374151; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem; }
        
        .legend-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin-top: 1rem; background: white; transition: background-color 0.3s; }
        .legend-table th, .legend-table td { padding: 0.5rem; border: 1px solid #e5e7eb; transition: border-color 0.3s; }
        .legend-table th { background-color: #f9fafb; text-align: left; font-weight: 700; transition: background-color 0.3s; }
        .legend-stamp, .vis-legend-icon { color: var(--btn-blue) !important; font-weight: 700 !important; font-family: var(--font-sans) !important; }
        .legend-stamp { display: inline-block; transform: rotate(-45deg); font-size: 0.65rem; }
        .vis-legend-icon { display: inline-block; }
        .hidden { display: none !important; }
        #customModal { backdrop-filter: blur(2px); }
    </style>
</head>
<body>
    <div id="customModal" class="fixed inset-0 bg-black bg-opacity-40 hidden z-[100] flex items-center justify-center transition-opacity duration-200">
        <div class="bg-white p-6 rounded-xl shadow-2xl max-w-sm w-full mx-4 border border-gray-200 transform scale-95 transition-transform duration-200" id="customModalInner">
            <div class="flex items-center gap-3 mb-3 text-yellow-600">
                <span class="material-symbols-outlined text-2xl">warning</span><h3 class="text-lg font-bold text-gray-900">Mode Conflict</h3>
            </div>
            <p id="modalMessage" class="text-gray-600 mb-6 leading-relaxed"></p>
            <div class="flex justify-end gap-3">
                <button onclick="closeModal()" class="px-4 py-2 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-100 transition border border-transparent">Cancel</button>
                <button id="modalConfirm" class="px-4 py-2 rounded-lg text-sm font-semibold bg-blue-500 text-white hover:bg-blue-600 transition shadow-sm">Confirm</button>
            </div>
        </div>
    </div>

    <div class="app-container">
        <div class="app-header">
            <div class="control-row">
                <div class="toggle-container">
                    <button id="btn-ltr" class="control-btn" onmousedown="event.preventDefault()" onclick="setDirection('ltr')" title="LTR"><span class="material-symbols-outlined">format_textdirection_l_to_r</span></button>
                    <button id="btn-auto" class="control-btn" onmousedown="event.preventDefault()" onclick="setDirection('auto')" title="Auto (Per Paragraph)"><span class="material-symbols-outlined">hdr_auto</span></button>
                    <button id="btn-rtl" class="control-btn" onmousedown="event.preventDefault()" onclick="setDirection('rtl')" title="RTL"><span class="material-symbols-outlined">format_textdirection_r_to_l</span></button>
                </div>
                <button id="vizToggleButton" class="control-btn" onmousedown="event.preventDefault()" onclick="toggleVisualizationMode()" title="Toggle Visualization"><span class="material-symbols-outlined">visibility</span></button>
                <div class="w-px h-6 bg-gray-300 mx-2"></div>
                <button id="tagsModeBtn" class="control-btn" onmousedown="event.preventDefault()" onclick="toggleTagsMode()" title="Tags and Placeholders Mode"><span class="material-symbols-outlined">frame_source</span></button>
                <button id="tagsScanBtn" class="control-btn hidden" onmousedown="event.preventDefault()" onclick="scanForTags()" title="Re-scan for tags and placeholders"><span class="material-symbols-outlined">frame_reload</span></button>
                <div class="w-px h-6 bg-gray-300 mx-2"></div>
                <button id="comparisonBtn" class="control-btn" onmousedown="event.preventDefault()" onclick="toggleComparisonMode()" title="Comparison Mode"><span class="material-symbols-outlined">view_column_2</span></button>
                <button id="diffToggleButton" class="control-btn hidden" onmousedown="event.preventDefault()" onclick="toggleDiffMode()" title="Show Diffs"><span class="material-symbols-outlined">text_compare</span></button>
                <div class="w-px h-6 bg-gray-300 mx-2"></div>
                <button id="segmentationBtn" class="control-btn" onmousedown="event.preventDefault()" onclick="toggleSegmentationMode()" title="Segmentation Mode"><span class="material-symbols-outlined">table_rows</span></button>
                
                <div id="segmentationToolbar" class="flex gap-2 hidden">
                    <button class="control-btn" onmousedown="event.preventDefault()" onclick="splitActiveSegment()" title="Split Segment at Cursor"><span class="material-symbols-outlined text-[1.1rem]">split_scene_2</span></button>
                    <button class="control-btn" onmousedown="event.preventDefault()" onclick="mergeActiveSegment()" title="Merge Segment with Next"><span class="material-symbols-outlined text-[1.1rem] block rotate-90">combine_columns</span></button>
                    <button class="control-btn" onmousedown="event.preventDefault()" onclick="alphabetizeSegments()" title="Alphabetize Segment Order"><span class="material-symbols-outlined text-[1.1rem]">list_arrow</span></button>
                    <button class="control-btn" onmousedown="event.preventDefault()" onclick="removeDuplicateSegments()" title="Remove Duplicates"><span class="material-symbols-outlined text-[1.1rem]">tab_close</span></button>
                </div>
                <div class="w-px h-6 bg-gray-300 mx-2"></div>
                <button class="control-btn" onmousedown="event.preventDefault()" onclick="customUndo()" title="Undo"><span class="material-symbols-outlined">undo</span></button>
                <button class="control-btn" onmousedown="event.preventDefault()" onclick="customRedo()" title="Redo"><span class="material-symbols-outlined">redo</span></button>
                <div class="w-px h-6 bg-gray-300 mx-2"></div>
                
                <div class="dropdown-wrapper">
                    <button id="insertDropdownBtn" class="control-btn relative" onmousedown="event.preventDefault()" onclick="toggleDropdown('insertDropdownMenu')" title="Insert Character">
                        <span class="material-symbols-outlined">add</span><span class="material-symbols-outlined absolute bottom-0 left-1/2 transform -translate-x-1/2 text-[10px] opacity-70 pointer-events-none">expand_more</span>
                    </button>
                    <div id="insertDropdownMenu" class="dropdown-menu hidden">
                        <button onmousedown="event.preventDefault()" onclick="insertChar('\u200F')" class="flex items-center gap-3"><span class="legend-stamp w-6 text-center">RLM</span> <span class="text-sm text-gray-700">RLM</span></button>
                        <button onmousedown="event.preventDefault()" onclick="insertChar('\u200E')" class="flex items-center gap-3"><span class="legend-stamp w-6 text-center">LRM</span> <span class="text-sm text-gray-700">LRM</span></button>
                        <button onmousedown="event.preventDefault()" onclick="insertChar('\u202B')" class="flex items-center gap-3"><span class="legend-stamp w-6 text-center">RLE</span> <span class="text-sm text-gray-700">RLE</span></button>
                        <button onmousedown="event.preventDefault()" onclick="insertChar('\u202A')" class="flex items-center gap-3"><span class="legend-stamp w-6 text-center">LRE</span> <span class="text-sm text-gray-700">LRE</span></button>
                        <button onmousedown="event.preventDefault()" onclick="insertChar('\u00A0')" class="flex items-center gap-3"><span class="vis-legend-icon text-lg w-6 text-center">∘</span> <span class="text-sm text-gray-700">NBSP</span></button>
                        <button onmousedown="event.preventDefault()" onclick="insertChar('\t')" class="flex items-center gap-3"><span class="vis-legend-icon w-6 text-center">→</span> <span class="text-sm text-gray-700">Tab</span></button>
                    </div>
                </div>
                <button id="alphabetizeBtn" class="control-btn" onmousedown="event.preventDefault()" onclick="handleAlphabetize()" title="Alphabetize Content"><span class="material-symbols-outlined">sort_by_alpha</span></button>
                <div style="flex-grow: 1;"></div>
                <div style="display: flex; gap: 0.5rem;">
                    <button class="control-btn" onmousedown="event.preventDefault()" onclick="saveText()" title="Save File"><span class="material-symbols-outlined">save</span></button>
                    <button class="control-btn" onmousedown="event.preventDefault()" onclick="openFile()" title="Open File"><span class="material-symbols-outlined">folder_open</span></button>
                </div>
            </div>
        </div>

        <div class="app-editor-area relative">
            <div id="editorGrid" class="editor-grid absolute inset-0">
                <div class="editor-col">
                    <div class="editor-label hidden" id="labelLeft">Original</div>
                    <div class="editor-wrapper"><div id="textInput" class="text-input show-vis" contenteditable="true" spellcheck="false" dir="auto" data-placeholder="Type or paste your text here..."></div></div>
                </div>
                <div class="editor-col hidden" id="rightCol">
                    <div class="editor-label" id="labelRight">Modified</div>
                    <div class="editor-wrapper"><div id="textInput2" class="text-input show-vis" contenteditable="true" spellcheck="false" dir="auto" data-placeholder="Type or paste your text here..."></div></div>
                </div>
            </div>
            <div id="segmentationGrid" class="hidden absolute inset-0 overflow-y-auto pb-8 pr-2 flex flex-col gap-3"></div>
        </div>

        <div class="app-footer">
            <div id="statsBar" class="stats-container"></div>
            <div class="tools-section">
                <div class="section-title"><span class="material-symbols-outlined">search</span> Find and Replace</div>
                <div class="flex gap-2 mb-2 items-center">
                    <input type="text" id="findInput" class="flex-1 p-2 border rounded outline-none" placeholder="Find text..." oninput="handleSearchChange()" style="border-color: #d1d5db;">
                    <input type="text" id="replaceInput" class="flex-1 p-2 border rounded outline-none" placeholder="Replace with..." style="border-color: #d1d5db;">
                    <select id="frTarget" class="p-2 border rounded hidden text-sm bg-white outline-none" style="border-color: #d1d5db;">
                        <option value="both">Both</option><option value="original">Original</option><option value="modified">Modified</option>
                    </select>
                </div>
                <div class="flex items-center gap-4">
                    <label class="flex items-center gap-1 text-sm cursor-pointer"><input type="checkbox" id="regexToggle" onchange="handleSearchChange()"> Regex</label>
                    <label class="flex items-center gap-1 text-sm cursor-pointer"><input type="checkbox" id="highlightToggle" onchange="handleSearchChange()"> Highlight Matches</label>
