                        } else if (isComparisonMode) {
                            let inOrig = tag.isPair ? (txt1.includes(tag.openText) || txt1.includes(tag.closeText)) : txt1.includes(tag.text); let inMod = tag.isPair ? (txt2.includes(tag.openText) || txt2.includes(tag.closeText)) : txt2.includes(tag.text);
                            if (inOrig && inMod) occurrenceStr = 'Original & Modified'; else if (inOrig) occurrenceStr = 'Original'; else if (inMod) occurrenceStr = 'Modified';
                        }
                        const occEl = document.getElementById('occ-' + tag.id); if (occEl) { occEl.textContent = occurrenceStr; occEl.title = occurrenceStr; }
                    });
                }
            } catch(e) { console.warn(e); }
        }

        function findNext() { const findStr = document.getElementById('findInput').value; if (findStr) window.find(findStr, false, false, true, false, false, false); }
        function replaceNext() {
            const findStr = document.getElementById('findInput').value; const replaceStr = document.getElementById('replaceInput').value; if (!findStr) return;
            const sel = window.getSelection();
            if (sel.rangeCount > 0 && !sel.isCollapsed) {
                const selectedText = sel.toString(); const isRegex = document.getElementById('regexToggle').checked; let isMatch = false;
                if (isRegex) { try { const rx = new RegExp('^' + findStr + '$', 'i'); isMatch = rx.test(selectedText); } catch(e) {} } else isMatch = selectedText.toLowerCase() === findStr.toLowerCase();
                if (isMatch) {
                    let activeEd = null; document.querySelectorAll('.text-input').forEach(ed => { if (ed.contains(sel.anchorNode)) activeEd = ed; });
                    if (activeEd) {
                        document.execCommand('insertText', false, replaceStr);
                        if (isComparisonMode && isDiffActive) {
                            saveCaret(activeEd);
                            if (activeEd === textInput) updateDiff(getRawText(textInput), null); else updateDiff(null, getRawText(textInput2));
                            restoreCaret();
                        }
                        else { formatEditor(activeEd); }
                        if (isSegmentationMode) { const match = activeEd.id.match(/seg-input-(\d+)/); if (match) segments[parseInt(match[1])].text = getRawText(activeEd); }
                        updateStats();
                        saveHistoryState();
                    }
                }
            } findNext();
        }

        function replaceAll() {
            const findStr = document.getElementById('findInput').value; const replaceStr = document.getElementById('replaceInput').value; if (!findStr) return;
            const isRegex = document.getElementById('regexToggle').checked; let regex;
            try { regex = isRegex ? new RegExp(findStr, 'g') : new RegExp(findStr.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'); } catch(e) { return; }
            if (isSegmentationMode) { segments.forEach((seg, i) => { const newText = seg.text.replace(regex, replaceStr); if (newText !== seg.text) { seg.text = newText; const input = document.getElementById(`seg-input-${i}`); if (input) setRawText(input, newText); } }); } 
            else {
                const target = isComparisonMode ? frTarget.value : 'original';
                if (target === 'both' || target === 'original') { const raw = getRawText(textInput); const newText = raw.replace(regex, replaceStr); if (newText !== raw) setRawText(textInput, newText); }
                if (isComparisonMode && (target === 'both' || target === 'modified')) {
                    const raw = getRawText(textInput2); const newText = raw.replace(regex, replaceStr); if (newText !== raw) setRawText(textInput2, newText);
                    if (isDiffActive) updateDiff(null, getRawText(textInput2)); 
                }
            }
            if(!isSegmentationMode) updateStats();
            saveHistoryState();
        }
        
        function saveText() { 
            let rawText = ''; if (isSegmentationMode) rawText = segments.map(s => s.text + s.trailingSpace).join(''); else rawText = isComparisonMode && activeInput === textInput2 ? getRawText(textInput2) : getRawText(activeInput);
            const b = new Blob([rawText], {type: 'text/plain'}); const a = document.createElement('a'); a.href = URL.createObjectURL(b); a.download = 'editor_export.txt'; a.click(); 
        }
        function openFile() { document.getElementById('fileInput').click(); }

        // ================= Event Listeners =================
        function handleKeydown(e) {
            const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0; const cmd = isMac ? e.metaKey : e.ctrlKey; activeInput = e.currentTarget;
            if (e.key === 'Tab') { e.preventDefault(); insertChar('\t'); return; }
            if (cmd) { 
                if (e.code === 'BracketRight') { e.preventDefault(); insertChar(e.shiftKey ? '\u202B' : '\u200F'); return; } 
                else if (e.code === 'BracketLeft') { e.preventDefault(); insertChar(e.shiftKey ? '\u202A' : '\u200E'); return; } 
                else if (e.key.toLowerCase() === 'z') { e.preventDefault(); if (e.shiftKey) customRedo(); else customUndo(); return; }
                else if (e.key.toLowerCase() === 'y') { e.preventDefault(); customRedo(); return; }
            }
        }

        document.addEventListener('keydown', (e) => {
            const isInput = e.target && ['INPUT', 'TEXTAREA'].includes(e.target.tagName);
            const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;
            const cmd = isMac ? e.metaKey : e.ctrlKey;
            
            if (cmd && e.key.toLowerCase() === 'z') {
                if (isInput) return; // let native input undo work
                e.preventDefault();
                if (e.shiftKey) customRedo(); else customUndo();
            }
            if (cmd && e.key.toLowerCase() === 'y') {
                if (isInput) return;
                e.preventDefault();
                customRedo();
            }
        });

        document.addEventListener('selectionchange', () => {
            if (document.activeElement && ['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) return;
            
            document.querySelectorAll('.is-selected').forEach(el => el.classList.remove('is-selected'));
            
            const sel = window.getSelection(); 
            if (!sel || sel.rangeCount === 0 || sel.isCollapsed) return;
            
            const range = sel.getRangeAt(0);
            let container = range.commonAncestorContainer; 
            if (container.nodeType === Node.TEXT_NODE) container = container.parentNode;
            
            let activeEd = container.closest ? container.closest('.text-input') : null;
            if (!activeEd) return;

            const elements = activeEd.querySelectorAll('.vis-ctrl, .app-tag, .app-tag-ph, .app-tag-custom, .vis-pilcrow, .vis-char');
            elements.forEach(node => {
                if (sel.containsNode(node, true)) {
                    node.classList.add('is-selected');
                }
            });
            
            const parentTag = container.closest('.app-tag, .app-tag-ph, .app-tag-custom, .vis-ctrl, .vis-pilcrow');
            if (parentTag && !parentTag.classList.contains('is-selected')) {
                parentTag.classList.add('is-selected');
            }
        });

        document.addEventListener('paste', (e) => {
            const sel = window.getSelection(); if (!sel || sel.isCollapsed === undefined) return;
            let isInsideEditor = textInput.contains(sel.anchorNode) || textInput2.contains(sel.anchorNode);
            if (!isInsideEditor && isSegmentationMode) document.querySelectorAll('#segmentationGrid .text-input').forEach(inp => { if (inp.contains(sel.anchorNode)) isInsideEditor = true; });
            if (!isInsideEditor) return;
            
            e.preventDefault();
            const text = (e.originalEvent || e).clipboardData.getData('text/plain');
            document.execCommand('insertText', false, text);
        });

        document.addEventListener('copy', (e) => {
            const sel = window.getSelection(); if (!sel || sel.isCollapsed) return;
            let activeEd = null;
            if (textInput.contains(sel.anchorNode)) activeEd = textInput;
            else if (textInput2.contains(sel.anchorNode)) activeEd = textInput2;
            else if (isSegmentationMode) {
                document.querySelectorAll('#segmentationGrid .text-input').forEach(inp => { if (inp.contains(sel.anchorNode)) activeEd = inp; });
            }
            if (!activeEd) return;
            
            e.preventDefault();
            
            let copiedText = '';
            if (saveCaret(activeEd)) {
                const fullRaw = getRawText(activeEd);
                restoreCaret();
                const startIdx = fullRaw.indexOf('\uE000');
                const endIdx = fullRaw.indexOf('\uE001');
                if (startIdx !== -1 && endIdx !== -1) {
                    copiedText = fullRaw.substring(startIdx + 1, endIdx);
                }
            }
            
            e.clipboardData.setData('text/plain', copiedText); 
            
            const clone = sel.getRangeAt(0).cloneContents(); const div = document.createElement('div'); div.appendChild(clone);
            div.querySelectorAll('.vis-pilcrow, .app-tag-hidden').forEach(el => el.remove());
            div.querySelectorAll('.vis-char, .vis-ctrl, .search-highlight').forEach(unwrap);
            e.clipboardData.setData('text/html', div.innerHTML);
        });

        let _mouseDownTag = null;
        let _mouseDownX = 0;
        let _mouseDownY = 0;

        document.addEventListener('dragstart', (e) => {
            const targetEl = e.target.nodeType === 3 ? e.target.parentNode : e.target;
            if (!targetEl || typeof targetEl.closest !== 'function') return;
            const editor = targetEl.closest('.text-input');
            if (!editor) return;
            
            clearTimeout(historyTimeout);
            saveHistoryState();

            const sel = window.getSelection();
            let dragText = '';

            window.__draggedSelectionRange = null;
            window.__draggedTag = null;
            window.__internalDrop = false;

            if (sel && !sel.isCollapsed && sel.containsNode(targetEl, true)) {
                dragText = serializeSelectionToRawText(sel);
                window.__draggedSelectionRange = sel.getRangeAt(0).cloneRange();
                
                const clone = sel.getRangeAt(0).cloneContents(); 
                const div = document.createElement('div'); div.appendChild(clone);
                div.querySelectorAll('.vis-pilcrow, .app-tag-hidden').forEach(el => el.remove());
                div.querySelectorAll('.vis-char, .vis-ctrl, .search-highlight').forEach(unwrap);
                e.dataTransfer.setData('text/html', div.innerHTML);
            } else {
                const tag = targetEl.closest('[draggable="true"]');
                if (tag) {
                    if (tag.hasAttribute('data-tag-raw')) dragText = tag.getAttribute('data-tag-raw');
                    else if (tag.classList.contains('vis-ctrl')) dragText = tag.textContent;
                    
                    window.__draggedTag = tag;
                    const clone = tag.cloneNode(true);
                    const div = document.createElement('div'); div.appendChild(clone);
                    e.dataTransfer.setData('text/html', div.innerHTML);
                } else return; 
            }

            if (dragText) {
                e.dataTransfer.setData('text/plain', dragText);
                e.dataTransfer.effectAllowed = 'copyMove';
            }
        });

        document.addEventListener('dragend', (e) => {
            if (!window.__internalDrop && e.dataTransfer.dropEffect === 'move') {
                if (window.__draggedSelectionRange) { try { window.__draggedSelectionRange.deleteContents(); } catch(err){} }
                if (window.__draggedTag) { try { window.__draggedTag.remove(); } catch(err){} }
                document.querySelectorAll('.text-input').forEach(ed => formatEditor(ed));
            }
            window.__draggedSelectionRange = null;
            window.__draggedTag = null;
            window.__internalDrop = false;
        });

        document.addEventListener('drop', (e) => {
            const targetEl = e.target.nodeType === 3 ? e.target.parentNode : e.target;
            if (!targetEl || typeof targetEl.closest !== 'function') return;
            const editor = targetEl.closest('.text-input');
            if (editor) {
                e.preventDefault();
                window.__internalDrop = true;
                const plainText = e.dataTransfer.getData('text/plain');
                if (!plainText) return;

                let dropRange;
                if (document.caretRangeFromPoint) {
                    dropRange = document.caretRangeFromPoint(e.clientX, e.clientY);
                } else if (document.caretPositionFromPoint) {
                    const pos = document.caretPositionFromPoint(e.clientX, e.clientY);
                    if (pos) {
                        dropRange = document.createRange();
                        dropRange.setStart(pos.offsetNode, pos.offset);
                        dropRange.collapse(true);
                    }
                }

                if (dropRange) {
                    const isMove = e.dataTransfer.dropEffect === 'move' || e.dataTransfer.dropEffect === 'none' || (!e.ctrlKey && !e.metaKey && !e.altKey);

                    let dropInside = false;
                    if (window.__draggedSelectionRange) {
                        try {
                            const r1 = dropRange.compareBoundaryPoints(Range.START_TO_START, window.__draggedSelectionRange);
                            const r2 = dropRange.compareBoundaryPoints(Range.START_TO_END, window.__draggedSelectionRange);
                            if (r1 >= 0 && r2 <= 0) dropInside = true;
                        } catch(err) {}
                    } else if (window.__draggedTag) {
                        try {
                            if (window.__draggedTag.contains(dropRange.startContainer)) dropInside = true;
                        } catch(err) {}
                    }

                    if (dropInside) {
                        return;
                    }

                    const marker = document.createElement('span');
                    marker.id = 'drop-marker';
                    dropRange.insertNode(marker);

                    if (isMove) {
                        if (window.__draggedSelectionRange) { try { window.__draggedSelectionRange.deleteContents(); } catch(err){} }
                        if (window.__draggedTag) { try { window.__draggedTag.remove(); } catch(err){} }
                    }

                    editor.focus();
                    const sel = window.getSelection();
                    sel.removeAllRanges();

                    if (document.body.contains(marker)) {
                        const newRange = document.createRange();
                        newRange.setStartBefore(marker);
                        newRange.collapse(true);
                        sel.addRange(newRange);
                        marker.remove();
                    } else {
                        const newRange = document.createRange();
                        newRange.selectNodeContents(editor);
                        newRange.collapse(false);
                        sel.addRange(newRange);
                    }

                    activeInput = editor;
                    document.execCommand('insertText', false, plainText);
                    formatEditor(editor);
                    setTimeout(() => saveHistoryState(), 100);
                }
                
                window.__draggedSelectionRange = null;
                window.__draggedTag = null;
            }
        });

        document.addEventListener('mousedown', (e) => {
            const targetEl = e.target.nodeType === 3 ? e.target.parentNode : e.target;
            document.querySelectorAll('.dropdown-menu').forEach(menu => { const btn = menu.previousElementSibling; if (!menu.classList.contains('hidden') && !menu.contains(targetEl) && !btn.contains(targetEl)) menu.classList.add('hidden'); });

            if (!targetEl || typeof targetEl.closest !== 'function') return;
            
            _mouseDownTag = targetEl.closest('.app-tag, .app-tag-ph, .app-tag-custom, .vis-ctrl, .vis-pilcrow');
            _mouseDownX = e.clientX;
            _mouseDownY = e.clientY;

            const editor = targetEl.closest('.text-input');
            if (editor) {
                if (targetEl.closest('input')) return;

                if (e.detail >= 4) {
                    e.preventDefault();
                    const sel = window.getSelection();
                    const range = document.createRange();
                    range.selectNodeContents(editor);
                    sel.removeAllRanges();
                    sel.addRange(range);
                } else if (e.detail === 3) {
                    e.preventDefault();
                    const sel = window.getSelection();
                    const range = document.createRange();
                    const block = targetEl.closest('.editor-block');
                    if (block) range.selectNodeContents(block);
                    else range.selectNodeContents(editor);
                    sel.removeAllRanges();
                    sel.addRange(range);
                } else if (e.detail === 1 && !e.shiftKey) {
                    const sel = window.getSelection();
                    
                    if (!sel.isCollapsed) {
                        let isInside = false;
                        const range = sel.getRangeAt(0);
                        const rects = range.getClientRects();
                        for (let i = 0; i < rects.length; i++) {
                            const r = rects[i];
                            if (e.clientX >= r.left - 5 && e.clientX <= r.right + 5 && e.clientY >= r.top - 5 && e.clientY <= r.bottom + 5) {
                                isInside = true;
                                break;
                            }
                        }

                        if (!isInside) {
                            let dropRange;
                            if (document.caretRangeFromPoint) {
                                dropRange = document.caretRangeFromPoint(e.clientX, e.clientY);
                            } else if (document.caretPositionFromPoint) {
                                const pos = document.caretPositionFromPoint(e.clientX, e.clientY);
                                if (pos) {
                                    dropRange = document.createRange();
                                    dropRange.setStart(pos.offsetNode, pos.offset);
                                    dropRange.collapse(true);
                                }
                            }
                            if (dropRange) {
                                sel.removeAllRanges();
                                sel.addRange(dropRange);
                                e.preventDefault();
                                editor.focus();
                            } else {
                                sel.removeAllRanges();
                            }
                        }
                    }
                }
            }
        });

        document.addEventListener('mouseup', (e) => {
            const targetEl = e.target.nodeType === 3 ? e.target.parentNode : e.target;
            if (!targetEl || typeof targetEl.closest !== 'function') return;
            const tag = targetEl.closest('.app-tag, .app-tag-ph, .app-tag-custom, .vis-ctrl, .vis-pilcrow');
            if (tag && tag === _mouseDownTag) {
                const dx = Math.abs(e.clientX - _mouseDownX);
                const dy = Math.abs(e.clientY - _mouseDownY);
                if (dx < 5 && dy < 5) {
                    const sel = window.getSelection();
                    const range = document.createRange();
                    range.selectNode(tag);
                    sel.removeAllRanges();
                    sel.addRange(range);
                }
            }
            _mouseDownTag = null;
        });

        document.addEventListener('DOMContentLoaded', () => {
            [textInput, textInput2].forEach(editor => {
                editor.addEventListener('keydown', handleKeydown);
                editor.addEventListener('input', () => {
                    if (isComparisonMode && isDiffActive) { 
                        saveCaret(editor); 
                        if (editor === textInput) updateDiff(getRawText(textInput), null); 
                        else updateDiff(null, getRawText(textInput2)); 
                        restoreCaret(); 
                    } 
                    else { formatEditor(editor); }
                    if(!isSegmentationMode) { 
                        clearTimeout(updateTimeout); 
                        updateTimeout = setTimeout(updateStats, 100); 
                    }
                    clearTimeout(historyTimeout);
                    historyTimeout = setTimeout(saveHistoryState, 400);
                });
                editor.addEventListener('focus', () => { activeInput = editor; activeSegmentIndex = -1; });
            });
            document.getElementById('fileInput').addEventListener('change', (e) => {
                const reader = new FileReader(); 
                reader.onload = (ev) => { 
                    setRawText(activeInput, ev.target.result);
                    if (isComparisonMode && isDiffActive && activeInput === textInput2) { updateDiff(null, getRawText(textInput2)); }
                    if (isSegmentationMode && activeSegmentIndex > -1) segments[activeSegmentIndex].text = getRawText(activeInput);
                    if(!isSegmentationMode) updateStats();
                    saveHistoryState();
                }; reader.readAsText(e.target.files[0]);
            });
            document.getElementById('vizToggleButton').classList.add('is-active-btn');
            setDirection('auto'); setRawText(textInput, ""); updateRuleHighlight(); updateStats();
            saveHistoryState();
        });
    </script>
</body>
