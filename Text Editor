        function toggleDropdown(id) {
            document.querySelectorAll('.dropdown-menu').forEach(m => { if (m.id !== id) m.classList.add('hidden'); });
            document.getElementById(id).classList.toggle('hidden');
        }
        function unwrap(el) { const p = el.parentNode; while (el.firstChild) p.insertBefore(el.firstChild, el); p.removeChild(el); }

        function rebuildPilcrows(editor) {
            editor.querySelectorAll('.vis-pilcrow:not(.diff-del):not(.diff-add)').forEach(el => el.remove());
            if (!editor.classList.contains('show-vis')) return;

            editor.querySelectorAll('br:not(.placeholder-br):not(.diff-deleted-br)').forEach(br => {
                const existingPilcrow = br.previousSibling && br.previousSibling.nodeType === Node.ELEMENT_NODE && br.previousSibling.classList.contains('vis-pilcrow');
                if (!existingPilcrow) {
                    const p = document.createElement('span'); p.className = 'vis-pilcrow inline-pilcrow'; p.contentEditable = 'false'; p.textContent = '¶';
                    if (br.parentNode) br.parentNode.insertBefore(p, br);
                }
            });

            const blocks = editor.querySelectorAll('.editor-block');
            blocks.forEach((b, i) => {
                const diffDelPilcrow = Array.from(b.childNodes).find(n => n.nodeType === Node.ELEMENT_NODE && n.classList.contains('vis-pilcrow') && n.classList.contains('diff-del'));
                if (diffDelPilcrow) return;

                let lastVis = b.lastChild;
                while(lastVis && (lastVis.nodeType === Node.TEXT_NODE && lastVis.nodeValue === '' || lastVis.classList && (lastVis.classList.contains('placeholder-br') || lastVis.id && lastVis.id.startsWith('caret')))) { lastVis = lastVis.previousSibling; }
                const endsBr = lastVis && lastVis.tagName === 'BR';
                const isLastBlock = i === blocks.length - 1;
                
                if (!isLastBlock && !endsBr) {
                    const p = document.createElement('span'); p.className = 'vis-pilcrow block-pilcrow'; p.contentEditable = 'false'; p.textContent = '¶';
                    const ph = b.querySelector('.placeholder-br');
                    if (ph && b === ph.parentNode) b.insertBefore(p, ph); else b.appendChild(p);
                }
            });
        }

        function wrapTextNodes(node) {
            const walker = document.createTreeWalker(node, NodeFilter.SHOW_TEXT, null, false);
            const nodes = []; let n;
            while (n = walker.nextNode()) {
                if (n.parentNode && (n.parentNode.classList.contains('vis-char') || n.parentNode.classList.contains('vis-ctrl') || n.parentNode.hasAttribute('data-tag-raw') || n.parentNode.classList.contains('format-wrapper-active') || n.parentNode.classList.contains('app-tag-hidden'))) continue;
                nodes.push(n);
            }
            nodes.forEach(tn => {
                targetRegex.lastIndex = 0;
                const text = tn.nodeValue; if (!targetRegex.test(text)) return;
                targetRegex.lastIndex = 0;
                const p = tn.parentNode; const frags = text.split(targetRegex); const frag = document.createDocumentFragment();
                frags.forEach(part => {
                    if (part === '') return;
                    if (targets[part]) {
                        const s = document.createElement('span'); s.className = targets[part].class; s.textContent = part; s.draggable = true;
                        if (targets[part].label) s.setAttribute('data-label', targets[part].label); frag.appendChild(s);
                    } else frag.appendChild(document.createTextNode(part));
                });
                p.replaceChild(frag, tn);
            });
        }

        function checkCanFormat(match, isPair) {
            const isHtml = /^<[^>]+>$/.test(match); const isEscape = /^\\[nrtbf\\\"\']$/.test(match);
            const stripped = match.replace(/^<|>$|^\[|\]$|^\{|\}$/g, '').replace(/^\//, '').toLowerCase().trim();
            const base = stripped.split(' ')[0].replace(/^(open|start|end|close|closing)/, '');
            const breaks = ['br', 'break', 'linebreak', 'line_break'];
            const fmts = ['b', 'i', 'u', 'a', 'p', 'div', 'span', 'strong', 'em', 'mark', 'bold', 'italic', 'underline', 'link', 'url', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6'];
            if (breaks.includes(base) || isEscape || (isHtml && match.toLowerCase().includes('br'))) return true;
            if (isPair && (fmts.includes(base) || isHtml)) return true;
            return false;
        }

        function getScannerText(editor) {
            let text = '';
            editor.querySelectorAll('.editor-block').forEach((block, index) => {
                let bt = ''; const walker = document.createTreeWalker(block, NodeFilter.SHOW_ALL, null, false); let node;
                while (node = walker.nextNode()) {
                    if (node.nodeType === Node.ELEMENT_NODE) {
                        if (node.hasAttribute('data-tag-raw')) bt += ' ' + node.getAttribute('data-tag-raw') + ' ';
                        else if (node.tagName === 'BR' && !node.classList.contains('placeholder-br') && !node.classList.contains('diff-deleted-br')) bt += '\n';
                    } else if (node.nodeType === Node.TEXT_NODE) {
                        let p = node.parentNode; let skip = false;
                        while(p && p !== block) {
                            if (p.hasAttribute('data-tag-raw') || p.classList.contains('vis-pilcrow') || p.classList.contains('app-tag-hidden')) { skip = true; break; }
                            p = p.parentNode;
                        }
                        if (!skip) bt += node.nodeValue;
                    }
                }
                text += bt; if (index < editor.querySelectorAll('.editor-block').length - 1) text += '\n';
            }); return text;
        }

        function wrapRegisteredTags(node) {
            if (!isTagsMode) return; const activeTags = tagRegistry.filter(t => t.enabled); if (activeTags.length === 0) return;
            const es = (s) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); const strs = [];
            activeTags.forEach(t => { if (t.isPair) { strs.push(t.openText); strs.push(t.closeText); } else strs.push(t.text); });
            strs.sort((a,b) => b.length - a.length); if (strs.length === 0) return;
            
            const rx = new RegExp(`(${strs.map(es).join('|')})`, 'g');
            const walker = document.createTreeWalker(node, NodeFilter.SHOW_TEXT, null, false); const nodes = []; let n;
            while(n = walker.nextNode()) {
                if (n.parentNode && (n.parentNode.classList.contains('vis-char') || n.parentNode.classList.contains('vis-ctrl') || n.parentNode.hasAttribute('data-tag-raw') || n.parentNode.classList.contains('app-tag-hidden'))) continue;
                nodes.push(n);
            }
            nodes.forEach(tn => {
                const text = tn.nodeValue; rx.lastIndex = 0; if (!rx.test(text)) return; rx.lastIndex = 0;
                const frags = text.split(rx); const parent = tn.parentNode; const frag = document.createDocumentFragment();
                frags.forEach(part => {
                    if (part === '') return;
                    const tObj = activeTags.find(t => (t.isPair ? (t.openText === part || t.closeText === part) : t.text === part));
                    if (tObj) {
                        const isOpener = tObj.isPair && part === tObj.openText; let el;
                        if (tObj.displayMode === 'tag') {
                            el = document.createElement('span'); el.className = 'app-tag bidi-isolate';
                            if (tObj.isPair) el.classList.add(isOpener ? 'tag-opener' : 'tag-closer'); else el.classList.add('tag-standalone');
                            el.textContent = part.replace(/^<|>$|^\[|\]$|^\{|\}$/g, '').replace(/^\//, ''); 
                            el.setAttribute('dir', 'ltr'); el.contentEditable = 'false'; el.draggable = true;
                        } else if (tObj.displayMode === 'placeholder') {
                            el = document.createElement('span'); el.className = 'app-tag-ph';
                            const pt = tObj.placeholderText || ' ';
                            const hasRTL = /[\u0590-\u05FF\u0600-\u06FF]/.test(pt);
                            const hasLTR = /[a-zA-Z0-9]/.test(pt);
                            let formattedPt = pt;
                            if (hasRTL && !hasLTR) formattedPt = '\u200F' + pt + '\u200F';
                            else if (hasLTR && !hasRTL) formattedPt = '\u200E' + pt + '\u200E';
                            el.textContent = formattedPt || ' '; 
                            el.contentEditable = 'false'; el.draggable = true;
                        } else if (tObj.displayMode === 'hide') {
                            el = document.createElement('span'); el.className = 'app-tag-hidden'; el.style.display = 'none'; el.setAttribute('dir', 'ltr'); el.contentEditable = 'false';
                        } else if (tObj.displayMode === 'format') {
                            const pClean = part.replace(/^<|>$|^\[|\]$|^\{|\}$/g, '').replace(/^\//, '').toLowerCase().trim(); const base = pClean.split(' ')[0];
                            if (['br','break','linebreak','line_break'].includes(base) || part.includes('\n') || part.includes('\\n') || part.includes('\\r')) { el = document.createElement('br'); } 
                            else { el = document.createElement('span'); el.style.display = 'none'; el.setAttribute('dir', 'ltr'); }
                        } else if (tObj.displayMode === 'custom') {
                            el = document.createElement('span'); el.className = 'app-tag-custom select-all';
                            let cHtml = tObj.customHtml || '';
                            if (tObj.isPair && !isOpener) {
                                const match = cHtml.match(/^<\s*([a-zA-Z0-9\-]+)/);
                                if (match) cHtml = `</${match[1]}>`;
                            }
                            el.innerHTML = cHtml; el.setAttribute('dir', 'ltr'); el.contentEditable = 'false'; el.draggable = true;
                        }
                        el.setAttribute('data-tag-raw', part); el.setAttribute('data-tag-id', tObj.id); el.setAttribute('data-display-mode', tObj.displayMode);
                        el.setAttribute('data-ph-text', tObj.placeholderText || ''); el.setAttribute('data-custom-html', tObj.customHtml || '');
                        frag.appendChild(el);
                    } else frag.appendChild(document.createTextNode(part));
                });
                parent.replaceChild(frag, tn);
            });
        }

        function applyFormatVisuals(editor) {
            if (!isTagsMode) return; const pairs = tagRegistry.filter(t => t.enabled && t.isPair && (t.displayMode === 'format' || t.displayMode === 'custom')); if (pairs.length === 0) return;
            editor.querySelectorAll('.editor-block').forEach(block => {
                pairs.forEach(pair => {
                    Array.from(block.querySelectorAll(`[data-tag-raw="${pair.openText.replace(/"/g, '\\"')}"]`)).forEach(opener => {
                        let curr = opener.nextSibling; const wrapNodes = []; let closer = null;
                        while (curr) { if (curr.nodeType === Node.ELEMENT_NODE && curr.getAttribute('data-tag-raw') === pair.closeText) { closer = curr; break; } wrapNodes.push(curr); curr = curr.nextSibling; }
                        if (closer && wrapNodes.length > 0) {
                            let w;
                            if (pair.displayMode === 'custom') {
                                const htmlStr = pair.customHtml || '';
                                const match = htmlStr.match(/^<\s*([a-zA-Z0-9\-]+)/);
                                if (match) {
                                    w = document.createElement(match[1]);
                                    const tempDiv = document.createElement('div'); tempDiv.innerHTML = htmlStr + `</${match[1]}>`;
                                    if (tempDiv.firstElementChild) { Array.from(tempDiv.firstElementChild.attributes).forEach(attr => w.setAttribute(attr.name, attr.value)); }
                                } else w = document.createElement('span');
                                w.className = (w.className ? w.className + ' ' : '') + 'format-wrapper-active';
                            } else {
                                w = document.createElement('span'); w.className = 'format-wrapper-active';
                                const pClean = pair.openText.replace(/^<|>$|^\[|\]$|^\{|\}$/g, '').replace(/^\//, '').toLowerCase().trim(); const base = pClean.split(' ')[0].replace(/^(open|start)/, '');
                                if (['b','bold','strong'].includes(base)) w.style.fontWeight = 'bold'; else if (['i','italic','em'].includes(base)) w.style.fontStyle = 'italic'; else if (['u','underline'].includes(base)) w.style.textDecoration = 'underline'; else if (base === 'mark') w.style.backgroundColor = 'yellow'; else if (['a','link','url'].includes(base)) { w.style.color = '#2563eb'; w.style.textDecoration = 'underline'; } else if (/^h[1-6]$/.test(base)) { w.style.fontWeight = 'bold'; w.style.fontSize = '1.2em'; }
                            }
                            if(opener.parentNode) {
                                opener.parentNode.insertBefore(w, wrapNodes[0]); wrapNodes.forEach(n => w.appendChild(n));
                            }
                        }
                    });
                });
            });
        }

        function applySearchHighlights(editor) {
            if (!document.getElementById('highlightToggle').checked) return;
            const findStr = document.getElementById('findInput').value; if (!findStr) return;
            const isRegex = document.getElementById('regexToggle').checked; let rx;
            try { rx = isRegex ? new RegExp(`(${findStr})`, 'g') : new RegExp(`(${findStr.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi'); } catch(e) { return; }
            const walker = document.createTreeWalker(editor, NodeFilter.SHOW_TEXT, null, false); const nodes = []; let node;
            while (node = walker.nextNode()) {
                if (node.parentNode && (node.parentNode.classList.contains('vis-char') || node.parentNode.classList.contains('vis-ctrl') || node.parentNode.classList.contains('search-highlight') || node.parentNode.hasAttribute('data-tag-raw') || node.parentNode.classList.contains('app-tag-hidden'))) continue;
                nodes.push(node);
            }
            nodes.forEach(tn => {
                const text = tn.nodeValue; rx.lastIndex = 0; if (!rx.test(text)) return;
                const p = tn.parentNode; const frags = text.split(rx); const frag = document.createDocumentFragment();
                frags.forEach(part => {
                    if (part === '') return; let isMatch = false;
                    if (isRegex) { try { const exactRx = new RegExp(`^${rx.source}$`, rx.flags.replace('g', '')); isMatch = exactRx.test(part); } catch(e){} } 
                    else isMatch = part.toLowerCase() === findStr.toLowerCase();
                    if (isMatch) { const span = document.createElement('span'); span.className = 'search-highlight bg-yellow-300 text-black rounded-sm px-[1px]'; span.textContent = part; frag.appendChild(span); } 
                    else frag.appendChild(document.createTextNode(part));
                }); p.replaceChild(frag, tn);
            });
        }

        function saveCaret(editor) {
            if (document.activeElement && ['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) return false;
            const sel = window.getSelection(); if (!sel || sel.rangeCount === 0) return false;
            const range = sel.getRangeAt(0); if (!editor.contains(range.commonAncestorContainer)) return false;
            const s = document.createElement('span'); s.id = 'caret-start'; const e = document.createElement('span'); e.id = 'caret-end';
            const r = range.cloneRange(); r.collapse(false); r.insertNode(e); range.collapse(true); range.insertNode(s); return true;
        }

        function restoreCaret() {
            const s = document.getElementById('caret-start'); const e = document.getElementById('caret-end'); if (!s || !e) return;
            const sel = window.getSelection(); const r = document.createRange(); r.setStartBefore(s); r.setEndBefore(e); sel.removeAllRanges(); sel.addRange(r); s.remove(); e.remove();
        }

        function formatEditor(editor) {
            if (editor.isFormatting) return;
            
            const flattenEmptyBlocks = () => {
                editor.querySelectorAll('.editor-block').forEach(b => {
                    let hasRealContent = false;
                    const walker = document.createTreeWalker(b, NodeFilter.SHOW_ALL, null, false);
                    let n;
                    while (n = walker.nextNode()) {
                        if (n.nodeType === Node.TEXT_NODE && n.nodeValue.length > 0) hasRealContent = true;
                        if (n.nodeType === Node.ELEMENT_NODE && (n.hasAttribute('data-tag-raw') || n.classList.contains('vis-char') || n.classList.contains('vis-ctrl'))) hasRealContent = true;
                    }
                    if (!hasRealContent) {
                        const carets = [];
                        Array.from(b.querySelectorAll('span[id^="caret-"]')).forEach(c => carets.push(c));
